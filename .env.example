# ── LLM API Key ────────────────────────────────────────────────────────────
# Paste your API key here. The system auto-detects the provider from the prefix:
#   sk-...      → OpenAI       (default model: gpt-4o)
#   sk-ant-...  → Anthropic    (default model: claude-3-5-sonnet)
#   gsk_...     → Groq         (default model: llama3-8b-8192)
#   AIzaSy...   → Google Gemini (default model: gemini-2.5-flash)
#   sk-or-...   → OpenRouter   (default model: llama-3.1-8b-instruct:free)
#
# If no key is set, the system runs in local transformer mode (slower, fully offline).
# You can also set the key at runtime via the web UI — no restart required.
LLM_API_KEY=your_api_key_here

# ── Optional: Override provider defaults ───────────────────────────────────
# Uncomment and set these only if you want to use a non-default model or endpoint.
# LLM_MODEL_NAME=gemini-2.5-flash
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_PROVIDER=local_transformers   # Force offline mode regardless of key

# ── Local Transformer Model (offline fallback) ─────────────────────────────
# Used when no API key is available. flan-t5-small is small and fast.
LOCAL_TRANSFORMER_MODEL=google/flan-t5-small
LOCAL_TRANSFORMER_MODEL_LOCAL_ONLY=true

# ── OCR for Scanned / Image-Only PDFs ──────────────────────────────────────
# Set ENABLE_LOCAL_OCR=true if your PDFs are scanned paper records (not text-layer PDFs).
# Requires Tesseract to be installed separately — see README for instructions.
ENABLE_LOCAL_OCR=true
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Path to Poppler bin directory — needed for pdf2image page rendering.
# Download from: https://github.com/oschwartz10612/poppler-windows/releases
# POPPLER_PATH=C:\poppler\Library\bin

# ── OCR Quality Settings ───────────────────────────────────────────────────
# These are sensible defaults. Adjust only if OCR quality is poor.
LOCAL_OCR_MAX_PAGES=100
LOCAL_OCR_DPI=240
LOCAL_OCR_MAX_IMAGE_DIM=3000
LOCAL_OCR_RENDER_BATCH_SIZE=1
LOCAL_OCR_MODEL=microsoft/trocr-small-printed
LOCAL_OCR_MAX_LINES_PER_PAGE=80
LOCAL_OCR_BATCH_SIZE=8

# ── EasyOCR Settings ───────────────────────────────────────────────────────
EASYOCR_DOWNLOAD_ENABLED=true
EASYOCR_GPU=false
EASYOCR_BATCH_SIZE=8
EASYOCR_USE_SUBPROCESS=true
EASYOCR_SUBPROCESS_CHUNK_PAGES=5
EASYOCR_WORKER_TIMEOUT_SECONDS=900
EASYOCR_TEXT_THRESHOLD=0.35
EASYOCR_LOW_TEXT=0.20
EASYOCR_LINK_THRESHOLD=0.35
EASYOCR_MAG_RATIO=1.75

# ── Safety ─────────────────────────────────────────────────────────────────
# Keep this false. Only set true if you deliberately want demo/hardcoded data.
ALLOW_HARDCODED_FALLBACK=false
