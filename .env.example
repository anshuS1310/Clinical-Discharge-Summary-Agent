# ==============================================================================
# Clinical Discharge Summary Agent - Configuration Environment Variables (Example)
# ==============================================================================

# 1. LLM API Key Configuration
# The system automatically detects the provider, model, and base URL based on the API key prefix:
# - Google Gemini: Keys starting with "AIzaSy" or "AQ." (Default model: gemini-2.5-flash)
# - OpenAI: Keys starting with "sk-" (Default model: gpt-4o)
# - Anthropic: Keys starting with "sk-ant-" (Default model: claude-3-5-sonnet-20240620)
# - OpenRouter: Keys starting with "sk-or-" (Default model: meta-llama/llama-3.1-8b-instruct:free)
# - Groq: Keys starting with "gsk_" (Default model: llama3-8b-8192)
#
# If no key is set, or if the key starts with "your_", it defaults to simulated offline mode.
LLM_API_KEY=your_api_key_here

# 2. Custom Model & API Endpoint Overrides (Optional)
# Uncomment and configure these if you are using a custom endpoint, reverse proxy, or specific model.
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o

# 3. Local Offline Transformers Mode (Optional)
# Force the system to run text generation using a local model on CPU.
# Requires installing extra packages: pip install transformers torch sentencepiece
# LLM_PROVIDER=local_transformers
# LOCAL_TRANSFORMER_MODEL=google/flan-t5-small

# 4. Scanned PDF OCR Configuration (Optional)
# If raw patient notes are in scanned PDF format (images), setting this to true enables local OCR extraction.
# Requires installing extra packages: pip install transformers pillow
# ENABLE_LOCAL_TRANSFORMER_OCR=false
# LOCAL_OCR_MODEL=microsoft/trocr-small-printed
# LOCAL_OCR_MAX_PAGES=5
